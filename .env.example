# From https://supabase.com/dashboard/project/{PROJECT_ID}/settings/general
MCP_USE_OAUTH_SUPABASE_PROJECT_ID=your-project-id

# Publishable key (sb_publishable_...). This is the modern replacement for the
# legacy anon JWT key. Find it under Project Settings → API Keys.
MCP_USE_OAUTH_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Absolute URL the browser uses to reach this server. Used to build the OAuth
# callback for Google/GitHub sign-in. In prod behind a proxy, set this to
# your public HTTPS URL. Omit for local dev and the request origin is used.
MCP_USE_OAUTH_SUPABASE_SITE_URL=http://localhost:3000

# In the Supabase Dashboard, under Authentication → OAuth Server, set the
# consent screen URL to the page this example hosts:
#   http://localhost:3000/oauth/consent
# Supabase redirects users there after /authorize; this example handles
# sign-in and consent, then hands back to Supabase to issue the auth code.
#
# Under Authentication → Providers, enable Google and GitHub (or just one —
# the buttons on the sign-in page show both). Add this callback URL to the
# allowed redirect URLs for each provider:
#   http://localhost:3000/oauth/callback
