{
  "name": "mcp-oauth-supabase-template",
  "type": "module",
  "version": "1.0.0",
  "description": "MCP server template with Supabase OAuth authentication",
  "license": "MIT",
  "main": "dist/server.js",
  "scripts": {
    "build": "pnpm build:css && mcp-use build",
    "build:css": "tailwindcss -i src/styles.css -o public/styles.css --minify",
    "dev:css": "tailwindcss -i src/styles.css -o public/styles.css --watch",
    "dev": "pnpm build:css && mcp-use dev",
    "start": "mcp-use start"
  },
  "dependencies": {
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.104.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hono": "^4.11.0",
    "lucide-react": "^0.575.0",
    "mcp-use": "^1.25.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.0",
    "@types/node": "^25.0.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "tailwindcss": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.26.0"
}
